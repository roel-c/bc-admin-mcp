# Required — BigCommerce API credentials
BC_STORE_HASH=your_store_hash
BC_AUTH_TOKEN=your_api_token

# Optional — BigCommerce client tuning (defaults match BC-Tool-Boundaries.md conservative mode)
# BC_REQUESTS_PER_SECOND=2.0
# BC_QUOTA_SAFETY_BUFFER=25
# BC_MAX_RETRIES=6
# BC_PRODUCT_BATCH_SIZE=10
# BC_VARIANT_BATCH_SIZE=10
# BC_INVENTORY_BATCH_SIZE=10
# BC_DEFAULT_PAGE_LIMIT=250
# BC_MAX_TOTAL_RECORDS=10000
# BC_DELAY_BETWEEN_CHUNKS_MS=500
# BC_MAX_WRITE_CONCURRENCY=1
# BC_CACHE_TTL_SECONDS=60

# Optional — MCP server configuration
# MCP_SERVER_NAME=bigcommerce-mcp
# MCP_SERVER_VERSION=0.1.0
# MCP_TRANSPORT=stdio   # or streamable-http / sse (non-stdio requires MCP_AUTH_TOKEN)
# MCP_ADDRESS=127.0.0.1
# MCP_PORT=8080

# Required for streamable-http / SSE — strong random secret for bearer auth
# MCP_AUTH_TOKEN=your_random_secret_here
